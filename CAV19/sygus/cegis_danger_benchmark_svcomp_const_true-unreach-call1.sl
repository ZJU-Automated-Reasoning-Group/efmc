(set-logic BV)
(synth-inv inv ((x (_ BitVec 32)) (y (_ BitVec 32))))
(define-fun pre ((x (_ BitVec 32)) (y (_ BitVec 32))) Bool (and (= x #b00000000000000000000000000000001) (= y #b00000000000000000000000000000000)))
(define-fun trans ((x (_ BitVec 32)) (x! (_ BitVec 32)) (y (_ BitVec 32)) (y! (_ BitVec 32))) Bool (and (bvult y #b00000000000000000000010000000000) (and (= x! #b00000000000000000000000000000000) (= y! (bvadd y #b00000000000000000000000000000001)))))
(define-fun post ((x (_ BitVec 32)) (y (_ BitVec 32))) Bool (or (= x #b00000000000000000000000000000000) (bvult y #b00000000000000000000010000000000)))
(inv-constraint inv pre trans post )
(check-synth)

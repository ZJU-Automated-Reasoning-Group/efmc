(set-logic BV)
(synth-inv inv ((x (_ BitVec 32)) (y (_ BitVec 32))))
(define-fun pre ((x (_ BitVec 32)) (y (_ BitVec 32))) Bool (and (= x #b00000000000000000000000000000000) (= y #b00000000000000000000000000000001)))
(define-fun trans ((x (_ BitVec 32)) (y (_ BitVec 32)) (x! (_ BitVec 32)) (y! (_ BitVec 32))) Bool (and (bvult x #b00000000000000000000000000000110) (and (= x! (bvadd x #b00000000000000000000000000000001)) (= y! (bvmul y #b00000000000000000000000000000010)))))
(define-fun post ((x (_ BitVec 32)) (y (_ BitVec 32))) Bool (or (= #b00000000000000000000000000000001 (bvurem y #b00000000000000000000000000000011)) (bvult x #b00000000000000000000000000000110)))
(inv-constraint inv pre trans post )
(check-synth)
